# The Handy Beaver - Environment Variables Template
# Copy to .env and fill in values

# ===== Cloudflare =====
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# ===== D1 Database =====
D1_DATABASE_ID=
D1_DATABASE_NAME=handy-beaver-db

# ===== R2 Storage =====
R2_BUCKET_IMAGES=handy-beaver-images
R2_BUCKET_ASSETS=handy-beaver-assets

# ===== Square Payments =====
SQUARE_APPLICATION_ID=
SQUARE_ACCESS_TOKEN=
SQUARE_LOCATION_ID=
SQUARE_ENVIRONMENT=sandbox

# ===== Facebook =====
FACEBOOK_PAGE_ID=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_PAGE_ACCESS_TOKEN=

# ===== Google Calendar =====
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALENDAR_ID=

# ===== ElevenLabs Voice =====
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# ===== Discord Notifications =====
DISCORD_WEBHOOK_URL=
DISCORD_CHANNEL_ID=1479281060222337034

# ===== Auth =====
JWT_SECRET=
MAGIC_LINK_SECRET=

# ===== Email (Resend) =====
RESEND_API_KEY=
EMAIL_FROM=noreply@thehandybeaver.com
