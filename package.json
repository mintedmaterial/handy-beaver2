  "bugs": {
    "url": "https://github.com/Atlas-Os1/handy-beaver/issues"
  },
  "homepage": "https://github.com/Atlas-Os1/handy-beaver#readme",
  "dependencies": {
    "@hono/zod-validator": "^0.7.6",
    "hono": "^4.12.5",
    "mimetext": "^3.0.28",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@cloudflare/puppeteer": "^1.0.6",
    "@cloudflare/workers-types": "^4.20260307.1",
    "typescript": "^5.9.3",
    "wrangler": "^4.71.0"
  }
