{
  "name": "handy-beaver",
  "version": "1.0.0",
  "description": "AI-powered traveling craftsman & maintenance service app for Southeast Oklahoma.",
  "main": "index.js",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create handy-beaver-db",
    "db:migrate": "wrangler d1 execute handy-beaver-db --file=./schema.sql",
    "db:migrate:local": "wrangler d1 execute handy-beaver-db --local --file=./schema.sql",
    "typecheck": "tsc --noEmit",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "changeset publish"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Atlas-Os1/handy-beaver.git"
  },
  "keywords": [],
